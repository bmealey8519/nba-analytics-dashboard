    <datasource caption='nba_analytics' inline='true' name='federated.11acfw50mip1yd13r6qaq1ypd5gp' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.1rv7pyq0ys2oky15eww3n0uwbh4h'>
            <connection authentication='username-password' class='postgres' dbname='nba_analytics' one-time-sql='' port='5432' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.1rv7pyq0ys2oky15eww3n0uwbh4h' name='Custom SQL Query' type='text'>WITH team_scores AS (&#13;
    SELECT&#13;
        home_team_id AS team_id,&#13;
        home_score AS points&#13;
    FROM games&#13;
&#13;
    UNION ALL&#13;
&#13;
    SELECT&#13;
        away_team_id AS team_id,&#13;
        away_score AS points&#13;
    FROM games&#13;
)&#13;
&#13;
SELECT&#13;
    t.full_name AS team_name,&#13;
    ROUND(AVG(ts.points), 2) AS ppg&#13;
FROM team_scores ts&#13;
JOIN teams t&#13;
    ON t.team_id = ts.team_id&#13;
GROUP BY t.full_name&#13;
ORDER BY ppg DESC</relation>
        <metadata-records>
          <metadata-record class='column'>
            <remote-name>team_name</remote-name>
            <remote-type>129</remote-type>
            <local-name>[team_name]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>team_name</remote-alias>
            <ordinal>1</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <width>100</width>
            <contains-null>true</contains-null>
            <collation flag='0' name='LEN_RUS' />
            <attributes>
              <attribute datatype='string' name='TypeIsVarchar'>&quot;true&quot;</attribute>
            </attributes>
            <object-id>[_7658E2611C66498D94EF366645634AA2]</object-id>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>ppg</remote-name>
