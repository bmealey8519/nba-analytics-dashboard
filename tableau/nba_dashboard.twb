            <properties context=''>
              <relation connection='postgres.1rv7pyq0ys2oky15eww3n0uwbh4h' name='Custom SQL Query' type='text'>WITH team_scores AS (&#13;
    SELECT&#13;
        home_team_id AS team_id,&#13;
        home_score AS points&#13;
    FROM games&#13;
&#13;
    UNION ALL&#13;
&#13;
    SELECT&#13;
        away_team_id AS team_id,&#13;
        away_score AS points&#13;
    FROM games&#13;
)&#13;
&#13;
SELECT&#13;
    t.full_name AS team_name,&#13;
    ROUND(AVG(ts.points), 2) AS ppg&#13;
FROM team_scores ts&#13;
JOIN teams t&#13;
    ON t.team_id = ts.team_id&#13;
GROUP BY t.full_name&#13;
ORDER BY ppg DESC</relation>
