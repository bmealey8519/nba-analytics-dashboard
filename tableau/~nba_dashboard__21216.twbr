          <zone forceUpdate='true' h='12273' id='12' type-v2='text' w='88563' x='500' y='87000'>
            <formatted-text>
              <run fontalignment='1' fontsize='12'>Key Insights</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontsize='12'> • Most game-to-game scoring changes fall within ±5 points, indicating relatively consistent scoring performances across the league. </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontsize='12'>• Luka Dončić, Nikola Jokić, and Domantas Sabonis dominated the league in triple-doubles. </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontsize='12'>• Several role players experienced short but highly efficient scoring streaks, dramatically outperforming their season averages. </run>
              <run fontalignment='1'>Æ&#10;</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='12273' id='13' type-v2='text' w='10437' x='89063' y='87000'>
            <formatted-text>
              <run fontsize='8'>Data Source: 2023–24 NBA Regular Season </run>
              <run>Æ&#10;&#10;</run>
              <run fontsize='8'>Database: PostgreSQL</run>
              <run>Æ&#10;</run>
